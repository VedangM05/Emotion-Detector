from flask import Flask, render_template, request
from EmotionDetection import emotion_detector

app = Flask(__name__)

@app.route("/emotionDetector")
def emotion_detect_route():
    """
    Route for analyzing emotion from textToAnalyze query parameter.
    """
    text_to_analyze = request.args.get('textToAnalyze')
    
    # Analyze the emotion using the package
    result = emotion_detector(text_to_analyze)
    
    # Return formatted result string according to project requirements
    return (
        f"For the given statement, the system response is "
        f"'anger': {result['anger']}, 'disgust': {result['disgust']}, "
        f"'fear': {result['fear']}, 'joy': {result['joy']}, "
        f"'sadness': {result['sadness']}. The dominant emotion is {result['dominant_emotion']}."
    )

@app.route("/")
def render_index_page():
    """
    Render main index page (index.html).
    """
    return render_template('index.html')

if __name__ == "__main__":
    app.run(host="0.0.0.0", port=5000)
